{
  "name": "omnidesk",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:worker": "pnpm --filter worker start:dev",
    "dev:ngrok": "node scripts/dev-ngrok.js",
    "docker:up": "docker compose --env-file .env.docker up --build -d",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:logs": "docker compose --env-file .env.docker logs -f",
    "docker:migrate": "docker compose --env-file .env.docker run --rm migrate",
    "docker:seed": "docker compose --env-file .env.docker run --rm seed",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:up": "docker compose --env-file .env.docker up -d postgres redis",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:reset": "pnpm --filter api exec prisma migrate reset --force",
    "db:seed": "pnpm --filter api prisma:seed",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  },
  "packageManager": "pnpm@9.15.4",
  "resolutions": {
    "ws": "^8.21.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "postcss": "^8.5.10"
  }
}
