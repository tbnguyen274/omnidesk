# OmniDesk Docker environment template.
# Copy to `.env.docker` for local Docker runs.
#
# Local/demo default:
# - NODE_ENV=development keeps /dev/* fallback endpoints available.
# - Provider modes default to mock so the stack can boot without external credentials.
#
# Production checklist:
# - Set NODE_ENV=production.
# - Replace JWT_SECRET and JWT_REFRESH_SECRET with long random values (32+ chars).
# - Set EMAIL_INBOUND_MODE=live, EMAIL_OUTBOUND_MODE=live, FACEBOOK_PROVIDER_MODE=live.
# - Fill all IMAP, SMTP, and Facebook credentials below.
# - Keep /dev/* endpoints disabled by using NODE_ENV=production.

NODE_ENV=development

DATABASE_URL=postgresql://omnidesk:omnidesk@postgres:5432/omnidesk?schema=public
POSTGRES_PORT=55432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

API_PORT=3000
WORKER_PORT=3001
WEB_ORIGIN=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_REALTIME_URL=http://localhost:3000/notifications

JWT_SECRET=local-dev-jwt-secret-change-before-production
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-before-production

EMAIL_PROVIDER_MODE=mock
EMAIL_INBOUND_MODE=mock
EMAIL_OUTBOUND_MODE=mock
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=support@example.com
EMAIL_POLL_INTERVAL_MS=30000
EMAIL_SYNC_SINCE_MINUTES=60
EMAIL_SYNC_MAX_MESSAGES=10

FACEBOOK_PROVIDER_MODE=mock
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_API_VERSION=v20.0
FACEBOOK_WEBHOOK_SIGNATURE_REQUIRED=true

# Optional ngrok settings for `pnpm dev:ngrok`.
NGROK_PORT=3000
NGROK_DOMAIN=
